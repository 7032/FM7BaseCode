# ============================================================
# config.mk — プロジェクト設定 (= 唯一の設定ファイル)
#
# ここの値だけ書き換えれば、Makefile / link.script / asm_ipl.s
# の参照は全部追従するように仕込んであります。直接 lwasm を
# 叩く時は make が渡している -D BODY_LOAD=$(ORG) を自分で
# 与えてください。
# ============================================================

# 生成物のファイル名 (build/<NAME>.bin / build/<NAME>.d77 / D77 ラベル)
NAME = hello

# 本体プログラム (crt0 + main) の開始アドレス
#   = Makefile の本体リンクアドレス
#   = link.script の `section code load` アドレス
#   = asm_ipl.s の BODY_LOAD (IPL が本体を展開する先 + JMP 先)
# この値は「我々の IPL」 が決めるので自由。 既定 $0400 は、 ブート ROM が
# IPL を置く $0100 (BASIC 標準) / $0300 (DOS) の 256byte 域を両方避けた
# 安全な最小アドレス。 ページ境界 ($xx00) に揃えること。
ORG  = 0x0400
